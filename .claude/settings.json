{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT=\"$(pwd)/.claude/plugins/superpowers\" bash \"$(pwd)/.claude/plugins/superpowers/hooks/session-start\""
          },
          {
            "type": "command",
            "command": "node \"$(pwd)/.claude/plugins/caveman/hooks/caveman-activate.js\""
