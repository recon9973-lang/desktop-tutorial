NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
KAKAO_API_KEY=your_kakao_api_key
KAKAO_SENDER_KEY=your_kakao_sender_key
KAKAO_TEMPLATE_RECOMMENDATION=your_template_id
KAKAO_TEMPLATE_REMINDER=your_template_id

# 공공데이터포털(data.go.kr) — 전국 약국/응급실 정보 (없으면 샘플 데이터로 동작)
DATA_GO_KR_KEY=your_data_go_kr_service_key

# 카카오맵 JavaScript 키 — 지도 임베드용 (없으면 목록만 표시). developers.kakao.com
# 웹앱에 노출되는 값이라 NEXT_PUBLIC_ 접두사 필수
NEXT_PUBLIC_KAKAO_MAP_KEY=your_kakao_map_js_key
