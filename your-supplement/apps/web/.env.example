# 당신의영양제 웹앱 환경변수 (Vercel Root Directory = your-supplement/apps/web)
# ⚠️ 모든 키는 선택사항입니다. 없어도 앱은 동작하며(샘플/플레이스홀더), 키를 넣으면 실데이터로 바뀝니다.

# 네이버쇼핑 검색 API — 성분별 '함량당 최저가' 실데이터 (없으면 예시 가격)
# developers.naver.com → 검색 API
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# 공공데이터포털(data.go.kr) — 전국 약국/응급실 실데이터 (없으면 샘플 목록)
# 국립중앙의료원 '전국 약국/응급의료기관 정보 조회 서비스' 활용신청
DATA_GO_KR_KEY=your_data_go_kr_service_key

# 식약처 건강기능식품 품목 OpenAPI — /products의 '국내 건강기능식품' 실데이터
# data.go.kr '식품의약품안전처_건강기능식품정보'(15056760) 활용신청 후,
# 명세의 '엔드포인트(상세조회) 전체 URL'을 그대로 입력 (serviceKey는 위 DATA_GO_KR_KEY 사용)
# 예) http://apis.data.go.kr/1471000/HtfsItemInfoService/getHtfsItem
MFDS_PRODUCT_API_URL=

# 식약처 DUR(의약품안전사용서비스) — /api/dur 병용금기 조회 (15059486 활용신청 후 명세 URL)
MFDS_DUR_API_URL=

# 식약처 기능성 원료 인정현황 — scripts/sync-mfds-materials.mjs 배치 적재용 (15058359)
MFDS_MATERIAL_API_URL=

# Health Canada LNHPD — /api/products 캐나다 제품(선택). 포털 명세의 리소스 URL
LNHPD_API_URL=

# NCBI(PubMed) E-utilities — /api/evidence-search. 키 없어도 동작(있으면 rate↑)
NCBI_API_KEY=

# 카카오 알림톡(발신대행사) — /api/kakao 발송. 대행사(예: Solapi/NHN Toast/BizM) 규격
ALIMTALK_API_URL=
ALIMTALK_API_KEY=
KAKAO_SENDER_KEY=
KAKAO_TEMPLATE_RECOMMENDATION=
KAKAO_TEMPLATE_REMINDER=

# 카카오맵 JavaScript 키 — /nearby 지도 임베드 (없으면 목록만, 지도 자리엔 안내)
# developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키
# 웹에 노출되는 값이라 NEXT_PUBLIC_ 접두사 필수 + 배포 도메인 등록 필요
NEXT_PUBLIC_KAKAO_MAP_KEY=your_kakao_map_js_key

# 식약처 의약품 낱알식별 정보 — /api/drug/search (약 검색·식별)
# data.go.kr '식품의약품안전처_의약품 낱알식별 정보'(15057639) 활용신청 후,
# 명세의 목록조회 엔드포인트 전체 URL 입력 (serviceKey는 위 DATA_GO_KR_KEY 사용)
# 예) http://apis.data.go.kr/1471000/MdcinGrnIdntfcInfoService01/getMdcinGrnIdntfcInfoList01
MFDS_PILL_API_URL=
